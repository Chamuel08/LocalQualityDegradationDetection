{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/local-quality-degradation-detection/schemas/quality-report.v1.json",
  "title": "QualityReport",
  "description": "V1 Agent Layer quality report (002-v1-agent-layer); superset of v0.1",
  "type": "object",
  "required": [
    "report_id",
    "video_id",
    "mode",
    "frame_index",
    "report_timestamp",
    "system_version",
    "overall_mos",
    "severity",
    "degradations",
    "decision_trace",
    "performance"
  ],
  "additionalProperties": false,
  "properties": {
    "report_id": { "type": "string", "minLength": 1 },
    "video_id": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["fast", "deep"]
    },
    "frame_index": { "type": "integer", "minimum": 0 },
    "report_timestamp": { "type": "string", "format": "date-time" },
    "system_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "overall_mos": { "type": "number", "minimum": 1.0, "maximum": 5.0 },
    "severity": {
      "type": "string",
      "enum": ["good", "minor", "moderate", "severe", "critical"]
    },
    "mos_breakdown": { "$ref": "#/$defs/MOSBreakdown" },
    "degradations": {
      "type": "array",
      "items": { "$ref": "#/$defs/DegradationItem" }
    },
    "degradation_summary": { "$ref": "#/$defs/DegradationSummary" },
    "decision_trace": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/TraceEntry" }
    },
    "vlm_reasoning_summary": {
      "type": ["array", "null"],
      "items": { "$ref": "#/$defs/VLMReasoningSummary" }
    },
    "agent_meta": { "$ref": "#/$defs/AgentMeta" },
    "performance": { "$ref": "#/$defs/PerformanceMetrics" }
  },
  "$defs": {
    "Evidence": {
      "type": "object",
      "required": ["method", "metric", "value", "threshold", "detail"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "metric": { "type": "string", "minLength": 1 },
        "value": { "type": "number" },
        "threshold": { "type": "number" },
        "detail": { "type": "string", "minLength": 1 },
        "attention_map": { "type": ["string", "null"] }
      }
    },
    "RootCauseHypothesis": {
      "type": "object",
      "required": ["cause", "confidence"],
      "additionalProperties": false,
      "properties": {
        "cause": {
          "type": "string",
          "enum": [
            "generation_artifact",
            "encoding_loss",
            "enhancement_artifact",
            "matting_error",
            "lighting_inconsistency",
            "other"
          ]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "VLMReasoning": {
      "type": "object",
      "required": ["reasoning", "vlm_confidence", "fusion_decision"],
      "additionalProperties": false,
      "properties": {
        "reasoning": { "type": "string", "minLength": 1 },
        "vlm_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "ux_impact": { "type": "string" },
        "fusion_decision": {
          "type": "string",
          "enum": ["agree", "vlm_override", "detector_override", "uncertain"]
        }
      }
    },
    "VLMReasoningSummary": {
      "type": "object",
      "required": ["degradation_id", "reasoning"],
      "properties": {
        "degradation_id": { "type": "string" },
        "reasoning": { "type": "string" },
        "region_type": { "type": "string" }
      }
    },
    "DegradationItem": {
      "type": "object",
      "required": [
        "degradation_id",
        "region_type",
        "degradation_type",
        "severity",
        "confidence",
        "mos_impact",
        "bbox",
        "frame_indices",
        "description",
        "detector",
        "evidence",
        "root_cause_hypothesis"
      ],
      "additionalProperties": false,
      "properties": {
        "degradation_id": { "type": "string", "minLength": 1 },
        "region_type": {
          "type": "string",
          "enum": ["face", "hair", "hand", "edge", "background", "body", "text_ui"]
        },
        "degradation_type": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["good", "minor", "moderate", "severe", "critical"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "mos_impact": { "type": "number", "maximum": 0 },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "integer", "minimum": 0 }
        },
        "frame_indices": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "description": { "type": "string", "minLength": 1 },
        "detector": {
          "type": "string",
          "enum": ["edge_bleed", "compression_artifact"]
        },
        "evidence": { "$ref": "#/$defs/Evidence" },
        "root_cause_hypothesis": { "$ref": "#/$defs/RootCauseHypothesis" },
        "vlm_reasoning": {
          "oneOf": [
            { "$ref": "#/$defs/VLMReasoning" },
            { "type": "null" }
          ]
        }
      }
    },
    "TraceEntry": {
      "type": "object",
      "required": [
        "stage",
        "module",
        "timestamp_ms",
        "duration_ms",
        "input_summary",
        "output_summary",
        "decision",
        "mode"
      ],
      "additionalProperties": false,
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "mode_select",
            "global_scan",
            "vlm_coarse",
            "routing",
            "detection",
            "vlm_confirm",
            "judge",
            "aggregation"
          ]
        },
        "module": { "type": "string", "minLength": 1 },
        "timestamp_ms": { "type": "number", "minimum": 0 },
        "duration_ms": { "type": "number", "minimum": 0 },
        "input_summary": { "type": "object" },
        "output_summary": { "type": "object" },
        "decision": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["fast", "deep"] }
      }
    },
    "AgentMeta": {
      "type": "object",
      "properties": {
        "rounds_executed": { "type": "integer", "minimum": 1, "maximum": 2 },
        "max_rounds_reached": { "type": "boolean" },
        "vlm_calls": { "type": "integer", "minimum": 0 },
        "judge_assessment": {
          "type": "string",
          "enum": ["consistent", "uncertain", "inconsistent"]
        }
      }
    },
    "PenaltyItem": {
      "type": "object",
      "required": ["source", "penalty", "reason"],
      "properties": {
        "source": { "type": "string" },
        "penalty": { "type": "number" },
        "effective_penalty": { "type": "number" },
        "decay_index": { "type": "integer", "minimum": 0 },
        "reason": { "type": "string" }
      }
    },
    "MOSBreakdown": {
      "type": "object",
      "required": ["base_mos", "total_penalty", "cap_applied", "penalties"],
      "properties": {
        "base_mos": { "type": "number" },
        "total_penalty": { "type": "number", "maximum": 0 },
        "cap_applied": { "type": "boolean" },
        "cap_reason": { "type": ["string", "null"] },
        "penalties": {
          "type": "array",
          "items": { "$ref": "#/$defs/PenaltyItem" }
        }
      }
    },
    "DegradationSummary": {
      "type": "object",
      "required": ["total_count", "by_severity", "by_detector"],
      "properties": {
        "total_count": { "type": "integer", "minimum": 0 },
        "by_severity": { "type": "object" },
        "by_detector": { "type": "object" },
        "by_root_cause": { "type": "object" },
        "top_issues": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 3
        }
      }
    },
    "PerformanceMetrics": {
      "type": "object",
      "required": ["total_ms", "global_scan_ms", "detection_ms", "aggregation_ms"],
      "properties": {
        "total_ms": { "type": "number", "minimum": 0 },
        "global_scan_ms": { "type": "number", "minimum": 0 },
        "detection_ms": { "type": "number", "minimum": 0 },
        "aggregation_ms": { "type": "number", "minimum": 0 },
        "vlm_ms": { "type": "number", "minimum": 0 },
        "judge_ms": { "type": "number", "minimum": 0 }
      }
    }
  }
}
