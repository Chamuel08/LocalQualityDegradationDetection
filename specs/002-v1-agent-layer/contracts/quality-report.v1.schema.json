{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/local-quality-degradation-detection/schemas/quality-report.v1.json",
  "title": "QualityReport",
  "description": "V1 Agent Layer quality report (002-v1-agent-layer); superset of v0.1",
  "type": "object",
  "required": [
    "report_id",
    "video_id",
    "mode",
    "frame_index",
    "report_timestamp",
    "system_version",
    "overall_mos",
    "severity",
    "degradations",
    "decision_trace",
    "performance"
  ],
  "additionalProperties": false,
  "properties": {
    "report_id": { "type": "string", "minLength": 1 },
    "video_id": { "type": "string", "minLength": 1 },
    "mode": {
      "type": "string",
      "enum": ["fast", "deep"]
    },
    "frame_index": { "type": "integer", "minimum": 0 },
    "report_timestamp": { "type": "string", "format": "date-time" },
    "system_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "overall_mos": {
      "type": ["number", "null"],
      "minimum": 1.0,
      "maximum": 5.0,
      "description": "帧级 MOS 总分，由无参考画质模型（默认 CLIP-IQA）直接预测并映射到 [1,5]。模型不可用时为 null，mos_unavailable_reason 给出原因，不回退默认分。"
    },
    "mos_unavailable_reason": {
      "type": ["string", "null"],
      "description": "overall_mos 为 null 时的原因；overall_mos 非 null 时为 null。"
    },
    "severity": {
      "type": "string",
      "enum": ["good", "minor", "moderate", "severe", "critical"]
    },
    "mos_breakdown": { "$ref": "#/$defs/MOSBreakdown" },
    "degradations": {
      "type": "array",
      "items": { "$ref": "#/$defs/DegradationItem" }
    },
    "degradation_summary": { "$ref": "#/$defs/DegradationSummary" },
    "decision_trace": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/TraceEntry" }
    },
    "vlm_reasoning_summary": {
      "type": ["array", "null"],
      "items": { "$ref": "#/$defs/VLMReasoningSummary" }
    },
    "agent_meta": { "$ref": "#/$defs/AgentMeta" },
    "performance": { "$ref": "#/$defs/PerformanceMetrics" },
    "scenario_attribution": {
      "type": ["array", "null"],
      "description": "业务场景归因（004）。把检出劣化映射到业务场景（转码增强/直播/推荐/AIGC 审核）+ 修复建议；未触发时为 null。",
      "items": { "$ref": "#/$defs/ScenarioAttribution" }
    },
    "quality_caption": {
      "type": ["object", "null"],
      "description": "VLM 画质自然语言描述（004）。报告级冗余字段（与 agent_meta.quality_caption 同值），便于不读 agent_meta 的下游直接取用；未触发时为 null。"
    }
  },
  "$defs": {
    "Evidence": {
      "type": "object",
      "required": ["method", "metric", "value", "threshold", "detail"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "metric": { "type": "string", "minLength": 1 },
        "value": { "type": "number" },
        "threshold": { "type": "number" },
        "detail": { "type": "string", "minLength": 1 },
        "attention_map": { "type": ["string", "null"] }
      }
    },
    "RootCauseHypothesis": {
      "type": "object",
      "required": ["cause", "confidence"],
      "additionalProperties": false,
      "properties": {
        "cause": {
          "type": "string",
          "enum": [
            "generation_artifact",
            "encoding_loss",
            "enhancement_artifact",
            "matting_error",
            "lighting_inconsistency",
            "other"
          ]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "VLMReasoning": {
      "type": "object",
      "required": ["reasoning", "vlm_confidence", "fusion_decision"],
      "additionalProperties": false,
      "properties": {
        "reasoning": { "type": "string", "minLength": 1 },
        "vlm_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "ux_impact": { "type": "string" },
        "fusion_decision": {
          "type": "string",
          "enum": ["agree", "vlm_override", "detector_override", "uncertain"]
        }
      }
    },
    "VLMReasoningSummary": {
      "type": "object",
      "required": ["degradation_id", "reasoning"],
      "properties": {
        "degradation_id": { "type": "string" },
        "reasoning": { "type": "string" },
        "region_type": { "type": "string" }
      }
    },
    "DegradationItem": {
      "type": "object",
      "required": [
        "degradation_id",
        "region_type",
        "degradation_type",
        "severity",
        "confidence",
        "bbox",
        "frame_indices",
        "description",
        "detector",
        "evidence",
        "root_cause_hypothesis"
      ],
      "additionalProperties": false,
      "properties": {
        "degradation_id": { "type": "string", "minLength": 1 },
        "region_type": {
          "type": "string",
          "enum": ["face", "hair", "hand", "edge", "background", "body", "text_ui"]
        },
        "degradation_type": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["good", "minor", "moderate", "severe", "critical"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "integer", "minimum": 0 }
        },
        "region_mask_rle": {
          "type": ["string", "null"],
          "description": "Row-major RLE bool mask: H,W:run1,run0,..."
        },
        "frame_indices": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "description": { "type": "string", "minLength": 1 },
        "detector": {
          "type": "string",
          "enum": [
            "edge_bleed",
            "compression_artifact",
            "blur_artifact",
            "mosaic_artifact",
            "banding_artifact",
            "background_artifact",
            "hair_texture",
            "face_artifact",
            "hand_anomaly"
          ]
        },
        "evidence": { "$ref": "#/$defs/Evidence" },
        "root_cause_hypothesis": { "$ref": "#/$defs/RootCauseHypothesis" },
        "vlm_reasoning": {
          "oneOf": [
            { "$ref": "#/$defs/VLMReasoning" },
            { "type": "null" }
          ]
        }
      }
    },
    "TraceEntry": {
      "type": "object",
      "required": [
        "stage",
        "module",
        "timestamp_ms",
        "duration_ms",
        "input_summary",
        "output_summary",
        "decision",
        "mode"
      ],
      "additionalProperties": false,
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "mode_select",
            "global_scan",
            "vlm_coarse",
            "routing",
            "detection",
            "vlm_confirm",
            "vlm_discover",
            "vlm_caption",
            "judge",
            "agent_step",
            "aggregation"
          ]
        },
        "module": { "type": "string", "minLength": 1 },
        "timestamp_ms": { "type": "number", "minimum": 0 },
        "duration_ms": { "type": "number", "minimum": 0 },
        "input_summary": { "type": "object" },
        "output_summary": { "type": "object" },
        "decision": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["fast", "deep"] }
      }
    },
    "AgentMeta": {
      "type": "object",
      "properties": {
        "rounds_executed": { "type": "integer", "minimum": 1, "maximum": 2 },
        "max_rounds_reached": { "type": "boolean" },
        "vlm_calls": { "type": "integer", "minimum": 0 },
        "judge_assessment": {
          "type": ["string", "null"],
          "enum": ["consistent", "uncertain", "inconsistent", null]
        },
        "agent_driven_vlm": { "type": "boolean" },
        "agent_steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step": { "type": "integer", "minimum": 1 },
              "thought": { "type": "string" },
              "action": {
                "type": "string",
                "enum": ["vlm_analyze", "rerun_detector", "dispatch_compression", "vlm_discover", "vlm_caption", "accept"]
              },
              "reason": { "type": ["string", "null"] },
              "observation": { "type": "string" },
              "latency_ms": { "type": "number", "minimum": 0 }
            }
          }
        },
        "vlm_discover_findings": {
          "type": "array",
          "description": "vlm_discover 工具的主动发现结果（V2）。VLM 对全帧扫描发现的 CV 规则检不到的语义异常；不含 bbox/mask，仅语义描述。空数组表示未触发或无发现。",
          "items": {
            "type": "object",
            "properties": {
              "degradation_type": { "type": "string" },
              "region_description": { "type": "string" },
              "severity": { "type": "string", "enum": ["minor", "moderate", "critical"] },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "reasoning": { "type": "string" },
              "mos_impact_estimate": { "type": "number" }
            }
          }
        },
        "quality_caption": {
          "type": ["object", "null"],
          "description": "vlm_caption 工具的画质自然语言描述（004）。VLM 对整帧生成的可解释画质总结；未触发时为 null。",
          "properties": {
            "overall_quality": { "type": "string", "enum": ["excellent", "good", "fair", "poor", "bad", "unknown"] },
            "caption": { "type": "string" },
            "primary_degradations": { "type": "array", "items": { "type": "string" } },
            "affected_regions": { "type": "array", "items": { "type": "string" } },
            "ux_impact": { "type": "string" }
          }
        }
      }
    },
    "MOSBreakdown": {
      "type": "object",
      "description": "帧级 MOS 总分的来源说明。MOS 与归因解耦：归因看 degradations[]，MOS 只是帧级一个总分，由无参考画质模型（默认 CLIP-IQA）直接预测。status=unavailable 时 mos 为 null 且 reason 给出原因，不回退默认分。",
      "required": ["model", "mos", "status"],
      "properties": {
        "model": { "type": "string", "enum": ["clip_iqa", "internal"], "description": "MOS 预测后端" },
        "mos": {
          "type": ["number", "null"],
          "minimum": 1.0,
          "maximum": 5.0,
          "description": "模型预测的帧级 MOS；不可用时为 null"
        },
        "status": { "type": "string", "enum": ["ok", "unavailable"] },
        "reason": { "type": ["string", "null"], "description": "status=unavailable 时的原因；ok 时为 null" }
      }
    },
    "DegradationSummary": {
      "type": "object",
      "required": ["total_count", "by_severity", "by_detector"],
      "properties": {
        "total_count": { "type": "integer", "minimum": 0 },
        "by_severity": { "type": "object" },
        "by_detector": { "type": "object" },
        "by_root_cause": { "type": "object" },
        "top_issues": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 3
        }
      }
    },
    "PerformanceMetrics": {
      "type": "object",
      "required": ["total_ms", "global_scan_ms", "detection_ms", "aggregation_ms"],
      "properties": {
        "total_ms": { "type": "number", "minimum": 0 },
        "global_scan_ms": { "type": "number", "minimum": 0 },
        "detection_ms": { "type": "number", "minimum": 0 },
        "aggregation_ms": { "type": "number", "minimum": 0 },
        "vlm_ms": { "type": "number", "minimum": 0 },
        "judge_ms": { "type": "number", "minimum": 0 }
      }
    },
    "ScenarioAttribution": {
      "type": "object",
      "description": "业务场景归因项（004）。把检出劣化映射到业务场景 + 修复建议。",
      "required": ["scenario", "confidence", "degradation_types", "evidence_refs", "recommendation"],
      "additionalProperties": false,
      "properties": {
        "scenario": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "degradation_types": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "recommendation": { "type": "string", "minLength": 1 }
      }
    }
  }
}
