{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/local-quality-degradation-detection/schemas/quality-report.v0.1.json",
  "title": "QualityReport",
  "description": "MVP v0.1 Fast Mode quality report (001-v0-fast-mvp)",
  "type": "object",
  "required": [
    "report_id",
    "video_id",
    "mode",
    "frame_index",
    "report_timestamp",
    "system_version",
    "overall_mos",
    "severity",
    "degradations",
    "decision_trace",
    "performance"
  ],
  "additionalProperties": false,
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "video_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["fast"]
    },
    "frame_index": {
      "type": "integer",
      "minimum": 0
    },
    "report_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "system_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "overall_mos": {
      "type": ["number", "null"],
      "minimum": 1.0,
      "maximum": 5.0,
      "description": "帧级 MOS 总分，由无参考画质模型（默认 CLIP-IQA）直接预测并映射到 [1,5]。模型不可用（依赖缺失/权重下载失败/推理异常/未提供帧）时为 null，此时 mos_unavailable_reason 给出原因，绝不回退到硬编码默认分。"
    },
    "mos_unavailable_reason": {
      "type": ["string", "null"],
      "description": "overall_mos 为 null 时的原因；overall_mos 非 null 时本字段为 null。"
    },
    "severity": {
      "type": "string",
      "enum": ["good", "minor", "moderate", "severe", "critical"]
    },
    "mos_breakdown": {
      "$ref": "#/$defs/MOSBreakdown"
    },
    "degradations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/DegradationItem"
      }
    },
    "degradation_summary": {
      "$ref": "#/$defs/DegradationSummary"
    },
    "decision_trace": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/TraceEntry"
      }
    },
    "vlm_reasoning_summary": {
      "type": ["array", "null"]
    },
    "performance": {
      "$ref": "#/$defs/PerformanceMetrics"
    },
    "scenario_attribution": {
      "type": ["array", "null"],
      "description": "业务场景归因：劣化 → 业务场景 → 修复建议。有劣化时由 ReportGenerator 无条件产出（v0.1/V1 共用）；无劣化时为 null。",
      "items": { "$ref": "#/$defs/ScenarioAttribution" }
    },
    "quality_caption": {
      "type": ["object", "null"],
      "description": "VLM 画质自然语言描述。仅 V1 Agent 触发 vlm_caption 时填充；v0.1 始终为 null。"
    }
  },
  "$defs": {
    "Evidence": {
      "type": "object",
      "required": ["method", "metric", "value", "threshold", "detail"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "metric": { "type": "string", "minLength": 1 },
        "value": { "type": "number" },
        "threshold": { "type": "number" },
        "detail": { "type": "string", "minLength": 1 },
        "attention_map": { "type": ["string", "null"] }
      }
    },
    "RootCauseHypothesis": {
      "type": "object",
      "required": ["cause", "confidence"],
      "additionalProperties": false,
      "properties": {
        "cause": {
          "type": "string",
          "enum": [
            "generation_artifact",
            "encoding_loss",
            "enhancement_artifact",
            "matting_error",
            "lighting_inconsistency",
            "other"
          ]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "DegradationItem": {
      "type": "object",
      "required": [
        "degradation_id",
        "region_type",
        "degradation_type",
        "severity",
        "confidence",
        "bbox",
        "frame_indices",
        "description",
        "detector",
        "evidence",
        "root_cause_hypothesis"
      ],
      "additionalProperties": false,
      "properties": {
        "degradation_id": { "type": "string", "minLength": 1 },
        "region_type": {
          "type": "string",
          "enum": ["face", "hair", "hand", "edge", "background", "body", "text_ui"]
        },
        "degradation_type": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["good", "minor", "moderate", "severe", "critical"]
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "integer", "minimum": 0 }
        },
        "region_mask_rle": {
          "type": ["string", "null"],
          "description": "Row-major RLE bool mask: H,W:run1,run0,..."
        },
        "frame_indices": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "description": { "type": "string", "minLength": 1 },
        "detector": {
          "type": "string",
          "enum": [
            "edge_bleed",
            "compression_artifact",
            "blur_artifact",
            "mosaic_artifact",
            "banding_artifact",
            "background_artifact",
            "hair_texture",
            "face_artifact",
            "hand_anomaly"
          ]
        },
        "evidence": { "$ref": "#/$defs/Evidence" },
        "root_cause_hypothesis": { "$ref": "#/$defs/RootCauseHypothesis" },
        "vlm_reasoning": { "type": ["object", "null"] }
      }
    },
    "TraceEntry": {
      "type": "object",
      "required": [
        "stage",
        "module",
        "timestamp_ms",
        "duration_ms",
        "input_summary",
        "output_summary",
        "decision",
        "mode"
      ],
      "additionalProperties": false,
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "mode_select",
            "global_scan",
            "vlm_coarse",
            "routing",
            "detection",
            "vlm_confirm",
            "aggregation"
          ]
        },
        "module": { "type": "string", "minLength": 1 },
        "timestamp_ms": { "type": "number", "minimum": 0 },
        "duration_ms": { "type": "number", "minimum": 0 },
        "input_summary": { "type": "object" },
        "output_summary": { "type": "object" },
        "decision": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["fast", "deep"] }
      }
    },
    "MOSBreakdown": {
      "type": "object",
      "description": "帧级 MOS 总分的来源说明。MOS 与归因解耦：归因看 degradations[]，MOS 只是帧级一个总分，由无参考画质模型（默认 CLIP-IQA）直接预测。status=unavailable 时 mos 为 null 且 reason 给出原因，不回退默认分。",
      "required": ["model", "mos", "status"],
      "properties": {
        "model": { "type": "string", "enum": ["clip_iqa", "internal"], "description": "MOS 预测后端" },
        "mos": {
          "type": ["number", "null"],
          "minimum": 1.0,
          "maximum": 5.0,
          "description": "模型预测的帧级 MOS；不可用时为 null"
        },
        "status": { "type": "string", "enum": ["ok", "unavailable"] },
        "reason": { "type": ["string", "null"], "description": "status=unavailable 时的原因；ok 时为 null" }
      }
    },
    "DegradationSummary": {
      "type": "object",
      "required": ["total_count", "by_severity", "by_detector"],
      "properties": {
        "total_count": { "type": "integer", "minimum": 0 },
        "by_severity": { "type": "object" },
        "by_detector": { "type": "object" },
        "by_root_cause": { "type": "object" },
        "top_issues": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 3
        }
      }
    },
    "PerformanceMetrics": {
      "type": "object",
      "required": ["total_ms", "global_scan_ms", "detection_ms", "aggregation_ms"],
      "properties": {
        "total_ms": { "type": "number", "minimum": 0 },
        "global_scan_ms": { "type": "number", "minimum": 0 },
        "detection_ms": { "type": "number", "minimum": 0 },
        "aggregation_ms": { "type": "number", "minimum": 0 }
      }
    },
    "ScenarioAttribution": {
      "type": "object",
      "description": "业务场景归因项：把检出劣化映射到业务场景 + 修复建议。",
      "required": ["scenario", "confidence", "degradation_types", "evidence_refs", "recommendation"],
      "additionalProperties": false,
      "properties": {
        "scenario": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "degradation_types": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "recommendation": { "type": "string", "minLength": 1 }
      }
    }
  }
}
